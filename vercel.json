{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "devCommand": "vite",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignoreCommand": "npm run build && echo true",
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}